import { Theme, AppI18n } from "../theme.slint";
import {
    CustomLineEdit,
    CustomButton,
} from "../components/form_widgets.slint";

export component NtpView inherits VerticalLayout {
    in-out property <string> ntp_host: "ntp.aliyun.com";
    in-out property <string> ntp_result: "";
    in-out property <bool> ntp_loading: false;

    callback request-ntp();

    spacing: 14px;
    padding-left: 4px;
    padding-right: 16px;
    padding-top: 8px;
    padding-bottom: 8px;

    Rectangle {
        background: Theme.card_bg;
        border-radius: 12px;
        border-width: 1px;
        border-color: Theme.border_color;
        min-height: 132px;

        VerticalLayout {
            padding: 24px;
            spacing: 10px;

            Text {
                text: AppI18n.t("ntp.title", [AppI18n.version]);
                color: Theme.text_primary;
                font-size: 24px;
                font-weight: 800;
            }

            Text {
                text: AppI18n.t("ntp.description", [AppI18n.version]);
                color: Theme.text_secondary;
                font-size: 14px;
                wrap: word-wrap;
            }
        }
    }

    Rectangle {
        background: Theme.card_bg;
        border-radius: 10px;
        border-width: 1px;
        border-color: Theme.border_color;

        VerticalLayout {
            padding: 18px;
            spacing: 14px;

            Text {
                text: AppI18n.t("ntp.server_label", [AppI18n.version]);
                font-size: 13px;
                color: Theme.text_secondary;
            }

            HorizontalLayout {
                spacing: 12px;

                CustomLineEdit {
                    horizontal-stretch: 1;
                    text <=> root.ntp_host;
                    placeholder-text: AppI18n.t("ntp.server_placeholder", [AppI18n.version]);
                }

                CustomButton {
                    width: 128px;
                    primary: true;
                    enabled: !root.ntp_loading;
                    text: root.ntp_loading ? AppI18n.t("ntp.querying", [AppI18n.version]) : AppI18n.t("ntp.query", [AppI18n.version]);
                    clicked => {
                        root.request-ntp();
                    }
                }
            }

            Rectangle {
                background: Theme.input_bg;
                border-radius: 8px;
                border-width: 1px;
                border-color: Theme.input_border;
                min-height: 72px;

                Text {
                    x: 12px;
                    y: 12px;
                    width: parent.width - 24px;
                    text: root.ntp_result == "" ? AppI18n.t("ntp.result_idle", [AppI18n.version]) : root.ntp_result;
                    color: root.ntp_result == "" ? Theme.text_secondary : Theme.text_primary;
                    font-size: 13px;
                    wrap: word-wrap;
                }
            }
        }
    }
}
